{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "{file:~/.config/opencode/AGENTS.md}"
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--slim",
        "--headless"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "opencode-wakatime",
    "opencode-cmux",
  ]
}
